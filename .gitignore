docs/issues/
*.csv

# macOS Finder metadata and notebook backups
.DS_Store
**/.DS_Store
*.ipynb.bak

# Obsidian per-machine vault state (not shared)
**/.obsidian/

# Archived / superseded material — kept locally, never pushed to remote.
# Moving a tracked file into archive/ shows as a delete in git status;
# stage and commit it to remove the file from the remote.
archive/

# Generated audio repair artifacts
data/audio-fix/check-cache/
data/audio-fix/original/
data/audio-fix/fixed/
data/audio-fix/streaming-work/
data/audio-fix/*.log
data/audio-fix/*.pid
data/audio-fix/*.tmp
data/audio-fix/all-audio-urls.txt
data/audio-fix/decode-report.jsonl
data/audio-fix/inventory.json
data/audio-fix/problematic-urls.txt
data/audio-fix/url-map.json
data/decode-failures.jsonl

# Local database files
**/*.sqlite
**/*.sqlite-shm
**/*.sqlite-wal

# Local Claude Code settings
.claude/settings.local.json

# Sensitive env files (each subdir's .gitignore also covers these)
**/.env
**/.env.*
!**/.env.example
!**/.env.test

# SSH keys and other secrets — must never be committed
**/*.pem
**/*.key
**/id_rsa
**/id_ed25519

# Build artifacts and dependencies
**/node_modules/
**/.svelte-kit/
**/build/
**/.vercel/

# Generated data outputs and local agent dirs (kept local, not pushed)
data/
.claude/

# LLM batch / categorization scratch outputs (generated, never committed)
batch_*.json
prompt_*.txt
responses/
scratch/
ui/tmp/
ui/.temp_*
ui/batch*
ui/BATCH_*
ui/output-*.json
ui/response.json
ui/15a4ef.json
ui/e9e1d5.json

# Eval harness (fix-task) — venv, large intermediates, run logs
.venv-eval/
data/eval/
eval/run.log
eval/run_tmux.log
__pycache__/
*.pyc
eval/run_resume.log
eval/loop*.log
eval/pool*.log
eval/val*.log

# Track 2 ASR auto-research: large local caches (not committed)
data/asr/audio/
data/asr/clips/
data/asr/meeting_json/
data/asr/*.out

# local CPU finetune venv
.venv-asr/

# matrix run intermediate caches (resumable)
data/reports/error-division/cache/

# local-only chart prompts (not for git)
docs/reports/img/CHART-PROMPTS.md

# next-batch selection: keep code+summaries+final list; ignore big binaries & calib audio
data/next-batch/*.parquet
data/next-batch/calib/
.venv-smoke/
.agents/
