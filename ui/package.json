{
	"name": "ui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 127.0.0.1 --port 5174",
		"build": "vite build",
		"preview": "vite preview",
		"postinstall": "node scripts/patch-svelte.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "node node_modules/.bin/vitest run --config vitest.config.ts --pool=vmThreads --no-file-parallelism",
		"test:watch": "node node_modules/.bin/vitest --config vitest.config.ts --pool=vmThreads --no-file-parallelism",
		"seed": "bun scripts/seed-dummy.ts",
		"build:cache": "tsx scripts/build-cache.ts",
		"e2e:install": "playwright install chromium",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@playwright/test": "^1.49.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/diff-match-patch": "^1.0.36",
		"@types/node": "^25.8.0",
		"@vitest/coverage-v8": "^4.1.6",
		"jsdom": "^29.1.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tsx": "^4.22.3",
		"typescript": "^6.0.2",
		"vite": "^8.0.0",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"better-sqlite3": "^12.10.0",
		"csv-parse": "^6.2.1",
		"diff-match-patch": "^1.0.5"
	}
}
